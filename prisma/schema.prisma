generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WaitlistSubscriber {
  id           String               @id @default(cuid())
  email        String               @unique
  referralCode String               @unique
  referralsMade Int                 @default(0)
  referredById String?
  referredBy   WaitlistSubscriber?  @relation("WaitlistReferrals", fields: [referredById], references: [id])
  referrals    WaitlistSubscriber[] @relation("WaitlistReferrals")
  isVerified   Boolean              @default(false)
  verifiedAt   DateTime?
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([referredById])
}

/** OTP challenge for /analytics (team @trenchers.ai only). Not waitlist data. */
model AnalyticsOtpChallenge {
  email        String   @id
  otpCode      String
  otpExpiresAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AnalyticsSession {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
