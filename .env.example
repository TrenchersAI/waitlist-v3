DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Resend (OTP + transactional). Without these, OTP APIs return 503.
# 1) resend.com → API Keys → create key → RESEND_API_KEY=re_...
# 2) Domains → add & verify your domain (DNS)
# 3) RESEND_FROM_EMAIL must use that domain, e.g. Trenchers <noreply@yourdomain.com>
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Trenchers <onboarding@yourdomain.com>"
WAITLIST_APP_NAME="Trenchers"

# Optional: restrict /analytics sign-in to this domain (default: trenchers.ai)
# INTERNAL_ANALYTICS_EMAIL_DOMAIN="trenchers.ai"

